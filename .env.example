# ==================================================================
# Meet補正システム 環境変数テンプレート
# ==================================================================
# このファイルをコピーして .env.local (開発用) または
# Renderの環境変数設定に貼り付けてください。
# 
# ⚠️  このファイル (.env.example) はGitにコミットしてよい
# ⚠️  .env や .env.local は絶対にGitにコミットしないこと
# ==================================================================

# ------------------------------------------------------------------
# データベース
# ------------------------------------------------------------------
# Render Managed PostgreSQL または Supabase の接続文字列
# 形式: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/meet_correction?sslmode=require"

# ------------------------------------------------------------------
# NextAuth / Auth.js
# ------------------------------------------------------------------
# 本番URL (末尾スラッシュなし)
NEXTAUTH_URL="https://your-app.onrender.com"

# セキュアなランダム文字列 (openssl rand -base64 32 で生成)
NEXTAUTH_SECRET="your-nextauth-secret-32-chars-minimum"

# ------------------------------------------------------------------
# Google OAuth (Google Cloud Console で作成)
# ------------------------------------------------------------------
# OAuth 2.0 クライアントID
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# OAuth 2.0 クライアントシークレット
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ------------------------------------------------------------------
# トークン暗号化キー
# ------------------------------------------------------------------
# OAuthトークンをDBに保存する際の暗号化キー
# 最低32文字。変更するとすべてのトークンが無効になるので注意
# 生成: openssl rand -hex 32
ENCRYPTION_KEY="your-32-char-minimum-encryption-key-here"

# ------------------------------------------------------------------
# 内部APIキー (Cron Job認証用)
# ------------------------------------------------------------------
# Render Cron JobがWebサーバーの内部APIを叩く際の認証キー
# 生成: openssl rand -hex 32
INTERNAL_API_KEY="your-internal-api-key-for-cron-jobs"

# ------------------------------------------------------------------
# アプリURL (Cron Jobから内部APIを叩く際に使用)
# ------------------------------------------------------------------
APP_URL="https://your-app.onrender.com"

# ------------------------------------------------------------------
# ジョブ設定 (オプション、デフォルト値あり)
# ------------------------------------------------------------------
# イベントスキャン間隔（分）
SCAN_INTERVAL_MINUTES=5

# 開始前再確認の分数
PRE_CHECK_MINUTES_BEFORE=30

# 最大リトライ回数
MAX_RETRY_ATTEMPTS=5

# ログレベル (debug, info, warn, error)
LOG_LEVEL=info

# ------------------------------------------------------------------
# 初期管理者設定 (seed実行時のみ使用)
# ------------------------------------------------------------------
# 以下は prisma/seed.ts 実行時のみ参照される
ADMIN_EMAIL="admin@yourschool.com"
ADMIN_PASSWORD="Admin@SecurePassword123!"
